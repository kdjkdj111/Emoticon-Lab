# Supabase Project URL
# Supabase 대시보드 -> Project Settings -> API 탭에서 Project URL 복사
VITE_SUPABASE_URL=https://[내프로젝트ref].supabase.co

# Supabase Anon Key (Public)
# Supabase 대시보드 -> Project Settings -> API 탭에서 Project API keys의 anon public 키 복사
VITE_SUPABASE_ANON_KEY=[자신의_ANON_KEY]

# Backend API Base URL (로컬 테스트용)
VITE_API_BASE_URL=http://localhost:8080
