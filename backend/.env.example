# Emoticon-Lab Backend Environment Variables
# 이 파일은 예시 파일입니다. 이 파일을 복사하여 `.env` 파일을 만들고 실제 키를 입력하세요.
# 주의: 실제 키가 들어간 `.env` 파일은 절대 깃허브에 올리면 안 됩니다!

# 1. Supabase 데이터베이스 설정
# Supabase 대시보드 -> Project Settings -> Database -> Connection string 탭의 'JDBC' 형식 URL을 복사
SUPABASE_DB_URL=jdbc:postgresql://[지역].pooler.supabase.com:6543/postgres?sslmode=require&prepareThreshold=0

# Supabase 프로젝트의 고유 유저명 (보통 postgres.[고유문자열])
SUPABASE_USER=postgres.[내프로젝트ref]

# Supabase 데이터베이스 비밀번호
SUPABASE_PASSWORD=[데이터베이스_비밀번호]

# 2. Gemini API 설정
# 구글 AI 스튜디오에서 발급받은 Gemini API 키
GEMINI_API_KEY=[자신의_GEMINI_API_KEY]
